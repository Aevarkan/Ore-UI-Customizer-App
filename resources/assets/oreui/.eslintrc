{
    "env": {
        "browser": true,
        "es6": true,
        "node": false
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/eslint-recommended",
        "plugin:@typescript-eslint/recommended-type-checked",
        "plugin:@typescript-eslint/stylistic-type-checked",
        "plugin:import/recommended",
        "plugin:import/typescript",
        "plugin:ore-ui/recommended-type-checked"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": ["@typescript-eslint/eslint-plugin", "no-restricted-syntax"],
    "rules": {
        "eslint-plugin-import/no-unresolved": "off",
        "import/no-unresolved": "off",
        "@typescript-eslint/no-non-null-assertion": "off",
        // "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-var-requires": "off",
        "@typescript-eslint/no-namespace": "off",
        // "@typescript-eslint/no-unused-vars": "off",
        "@typescript-eslint/no-unused-vars": [
            "warn",
            {
                "args": "all",
                "argsIgnorePattern": "(?:^_|^args)",
                "caughtErrors": "all",
                "caughtErrorsIgnorePattern": "^_",
                "destructuredArrayIgnorePattern": "^_",
                "vars": "local",
                "varsIgnorePattern": "^_",
                "ignoreRestSiblings": true
            }
        ],
        // "@typescript-eslint/no-inferrable-types": "off",
        "@typescript-eslint/no-empty-function": ["warn", { "allow": ["arrowFunctions", "constructors", "decoratedFunctions"] }],
        "@typescript-eslint/no-empty-interface": "off",
        "@typescript-eslint/ban-ts-comment": [
            "off",
            {
                "ts-check": false,
                "ts-expect-error": "allow-with-description",
                "ts-ignore": "allow-with-description",
                "ts-nocheck": "allow-with-description"
            }
        ],
        "@typescript-eslint/no-non-null-asserted-optional-chain": "off",
        "@typescript-eslint/no-unnecessary-type-constraint": "off",
        "@typescript-eslint/consistent-indexed-object-style": "off",
        "@typescript-eslint/no-confusing-non-null-assertion": "off",
        "@typescript-eslint/prefer-nullish-coalescing": [1, { "ignoreMixedLogicalExpressions": true }],
        "@typescript-eslint/triple-slash-reference": "off",
        "@typescript-eslint/explicit-function-return-type": "error",
        "@typescript-eslint/explicit-member-accessibility": "error",
        "@typescript-eslint/no-confusing-void-expression": ["error", { "ignoreVoidOperator": true }],
        "@typescript-eslint/no-import-type-side-effects": "error",
        // "@typescript-eslint/no-loop-func": "error", // Too buggy to use atm.
        "@typescript-eslint/no-misused-spread": "error",
        // "@typescript-eslint/no-unnecessary-condition": "warn", // TODO: Enable this and fix all the warnings from it.
        "@typescript-eslint/no-unnecessary-parameter-property-assignment": "warn",
        "@typescript-eslint/no-unnecessary-qualifier": "error",
        "@typescript-eslint/prefer-reduce-type-parameter": "error",
        "@typescript-eslint/prefer-return-this-type": "error",
        "@typescript-eslint/promise-function-async": "error",
        "@typescript-eslint/related-getter-setter-pairs": "warn",
        "@typescript-eslint/require-array-sort-compare": "error",
        "@typescript-eslint/return-await": ["error", "always"],
        // "@typescript-eslint/strict-boolean-expressions": "error", // TODO: Find a way to enable this while allowing unnecessary falsy checks on non-nullable objects.
        // "@typescript-eslint/strict-void-return": "error", // TODO: Enable this once the update adding it is released.
        "@typescript-eslint/switch-exhaustiveness-check": ["error", { "requireDefaultForNonUnion": true }],
        "@typescript-eslint/unified-signatures": [
            "error",
            {
                "ignoreDifferentlyNamedParameters": true,
                "ignoreOverloadsWithDifferentJSDoc": true
            }
        ],
        "@typescript-eslint/use-unknown-in-catch-callback-variable": "error",
        "array-callback-return": "error",
        "curly": ["warn", "multi-line"],
        "default-case": "warn",
        "default-case-last": "error",
        "eqeqeq": "error",
        // "func-name-matching": ["warn", "always", { "considerPropertyDescriptor": true }],
        "func-names": "warn",
        "grouped-accessor-pairs": "error",
        "guard-for-in": "warn",
        "logical-assignment-operators": "error",
        "no-constant-condition": "off",
        "no-constructor-return": "warn",
        "no-control-regex": "off",
        "no-debugger": "warn",
        "no-else-return": "warn",
        "no-empty": ["warn", { "allowEmptyCatch": true }],
        "no-extra-bind": "warn",
        "no-extra-label": "warn",
        // Only disallow double negation conversion (+ should be used instead).
        "no-implicit-coercion": ["error", { "allow": ["~", "!!", "+", "-", "*"] }],
        "no-inner-declarations": "warn",
        "no-irregular-whitespace": ["error", { "skipComments": true }],
        "no-iterator": "error",
        "no-lone-blocks": "warn",
        "no-lonely-if": "warn",
        "no-promise-executor-return": ["error", { "allowVoid": true }],
        "no-sparse-arrays": "off",
        "no-template-curly-in-string": "warn",
        "no-undef-init": "error",
        "no-unreachable-loop": "error",
        "no-useless-computed-key": "warn",
        "no-useless-concat": "warn",
        "no-restricted-syntax": [
            "error",
            { "selector": "AssignmentExpression[operator='+='][right.value=1]", "message": "Use ++ instead of += 1." },
            {
                "selector": "AssignmentExpression[operator='+='][right.type='UnaryExpression'][right.operator='+'][right.argument.type='Literal'][right.argument.value=1]",
                "message": "Use ++ instead of += +1."
            },
            {
                "selector": "AssignmentExpression[operator='-='][right.type='UnaryExpression'][right.operator='-'][right.argument.type='Literal'][right.argument.value=1]",
                "message": "Use ++ instead of -= -1."
            },
            { "selector": "AssignmentExpression[operator='-='][right.value=1]", "message": "Use -- instead of -= 1." },
            {
                "selector": "AssignmentExpression[operator='+='][right.type='UnaryExpression'][right.operator='-'][right.argument.type='Literal'][right.argument.value=1]",
                "message": "Use -- instead of += -1."
            },
            {
                "selector": "AssignmentExpression[operator='-='][right.type='UnaryExpression'][right.operator='+'][right.argument.type='Literal'][right.argument.value=1]",
                "message": "Use -- instead of -= +1."
            }
        ],
        "no-var": "off",
        "object-shorthand": ["error", "properties"],
        "operator-assignment": "error",
        "prefer-const": [
            "warn",
            {
                "destructuring": "all",
                "ignoreReadBeforeAssign": true
            }
        ],
        "prefer-exponentiation-operator": "error",
        "prefer-numeric-literals": "error",
        "prefer-object-spread": "warn",
        "prefer-rest-params": "off",
        "prefer-template": "warn",
        // "preserve-caught-error": "error", // TODO: Enable this once you patch the Error constructor to support a cause value.
        "require-atomic-updates": "error",
        "symbol-description": "error",
        "yoda": ["error", "never", { "exceptRange": true }]
    },
    "reportUnusedDisableDirectives": true,
    "ignorePatterns": ["*.js"],
    "root": true,
    "parserOptions": { "ecmaVersion": 2022, "sourceType": "script", "project": true }
}
